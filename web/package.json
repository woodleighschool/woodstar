{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && touch dist/.gitkeep",
    "preview": "vite preview",
    "lint": "eslint 'src/**/*.{ts,tsx,js,jsx}' '*.{js,ts}' && tsc -b",
