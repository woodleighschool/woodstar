{
  "name": "woodstar-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm run gen-api-docs && docusaurus start",
    "build": "pnpm run gen-api-docs && docusaurus build",
    "serve": "docusaurus serve",
    "lint": "oxlint . && pnpm run typecheck",
    "typecheck": "pnpm run gen-api-docs && tsc",
    "format": "oxfmt",
    "clean-api-docs": "docusaurus clean-api-docs all",
    "gen-api-docs": "pnpm run clean-api-docs && docusaurus gen-api-docs all"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.2",
    "@docusaurus/faster": "3.10.2",
    "@docusaurus/preset-classic": "3.10.2",
    "@easyops-cn/docusaurus-search-local": "^0.55.2",
    "@mdx-js/react": "^3.1.1",
    "clsx": "^2.1.1",
    "docusaurus-plugin-llms": "^0.5.0",
    "docusaurus-plugin-openapi-docs": "^5.1.2",
    "docusaurus-plugin-sass": "^0.2.6",
    "docusaurus-theme-openapi-docs": "^5.1.2",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sass": "^1.101.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.2",
    "@docusaurus/tsconfig": "3.10.2",
    "@docusaurus/types": "3.10.2",
    "@types/react": "^19.2.17",
    "typescript": "~6.0.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=24.18.0"
  },
  "packageManager": "pnpm@11.15.0"
}
