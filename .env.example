WOODSTAR_HOST=0.0.0.0
WOODSTAR_PORT=8443
WOODSTAR_URL=https://woodstar:8443
WOODSTAR_TLS_CERT_FILE=./tmp/tls/woodstar.pem
WOODSTAR_TLS_KEY_FILE=./tmp/tls/woodstar-key.pem
WOODSTAR_DATABASE_URL=postgres://woodstar:woodstar@localhost:5432/woodstar?sslmode=disable
WOODSTAR_SESSION_SECRET=replace-with-at-least-32-characters
WOODSTAR_SESSION_COOKIE_SECURE=true
WOODSTAR_LOG_LEVEL=debug
WOODSTAR_OIDC_ISSUER_URL=
WOODSTAR_OIDC_CLIENT_ID=
WOODSTAR_OIDC_CLIENT_SECRET=
WOODSTAR_OIDC_REDIRECT_URL=
WOODSTAR_OIDC_SCOPES=openid,email,profile
WOODSTAR_OIDC_EMAIL_CLAIM=email
WOODSTAR_ENTRA_TENANT_ID=
WOODSTAR_ENTRA_CLIENT_ID=
WOODSTAR_ENTRA_CLIENT_SECRET=
WOODSTAR_ENTRA_TRANSITIVE_GROUPS=false
WOODSTAR_ENTRA_SYNC_INTERVAL=1h
WOODSTAR_STORAGE_KIND=file
WOODSTAR_STORAGE_FILE_ROOT=./tmp/storage
WOODSTAR_STORAGE_S3_BUCKET=
WOODSTAR_STORAGE_S3_REGION=
WOODSTAR_STORAGE_S3_ENDPOINT=
WOODSTAR_STORAGE_S3_PUBLIC_ENDPOINT=
WOODSTAR_STORAGE_S3_ACCESS_KEY=
WOODSTAR_STORAGE_S3_SECRET_KEY=
WOODSTAR_STORAGE_S3_PATH_STYLE=false
WOODSTAR_STORAGE_S3_PRESIGN_TTL=15m

# woodstar mdp (distribution point worker) -- runs as a separate process
WOODSTAR_MDP_SERVER_URL=https://woodstar:8443
WOODSTAR_MDP_SERVER_CA_FILE=./tmp/tls/ca/rootCA.pem
WOODSTAR_MDP_KEY=
WOODSTAR_MDP_DATA_DIR=./tmp/mdp
WOODSTAR_MDP_LISTEN_ADDR=:8090
WOODSTAR_MDP_TLS_CERT_FILE=./tmp/tls/woodstar.pem
WOODSTAR_MDP_TLS_KEY_FILE=./tmp/tls/woodstar-key.pem
WOODSTAR_MDP_LOG_LEVEL=debug
WOODSTAR_MDP_DOWNLOAD_CONCURRENCY=4
